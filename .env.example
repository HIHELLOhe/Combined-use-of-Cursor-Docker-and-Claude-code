# Example environment variables for Docker + Cursor + Claude Code
# Copy this file to ".env" and fill in your real values locally.
# Never commit your real .env file to any public repository.

# Official Anthropic Claude API key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_official_claude_api_key_here

# Optional: additional environment variables for your own projects.
# PROJECT_NAME=my_project

